# ============================================
# 轻聊 · 环境变量配置
# 复制此文件为 .env 并填入真实值即可启动
#   cp env.example .env
# ============================================

# 必填：Supabase 项目地址
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# 必填：Supabase 匿名密钥（anon key）
SUPABASE_ANON_KEY=your-anon-key-here

# 可选：服务端口（默认 8766）
# PORT=8766
